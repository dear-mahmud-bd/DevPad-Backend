# ─── Application ────────────────────────────────────────────────
APP_ENV=development                  # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_USER=devpad
POSTGRES_PASSWORD=devpad_secret
POSTGRES_DB=devpad_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://devpad:devpad_secret@postgres:5432/devpad_db
# Async URL (used by SQLAlchemy async session)
DATABASE_ASYNC_URL=postgresql+asyncpg://devpad:devpad_secret@postgres:5432/devpad_db

# ─── MongoDB ─────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=devpad_db

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600                       # seconds; note cache expiry

# ─── Kafka ───────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka1:9092,kafka2:9093,kafka3:9094
KAFKA_TOPIC=devpad_events
KAFKA_CONSUMER_GROUP=devpad_consumer_group

# ─── Elasticsearch ───────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=devpad_notes
ES_JAVA_OPTS=-Xms256m -Xmx256m

# ─── JWT Auth ────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Email (dev uses Mailpit on port 1025) ───────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@devpad.local
SMTP_TLS=false                       # true in production

# ─── Trash auto-delete ───────────────────────────────────────────
TRASH_AUTO_DELETE_DAYS=15

# ─── Roles ───────────────────────────────────────────────────────
# Comma-separated list of emails that get SUPER_ADMIN role on signup
SUPER_ADMIN_EMAILS=admin@devpad.local

# ─── Instance identity (set per container in docker-compose) ─────
INSTANCE_ID=api1                     # api1 | api2 — shows in X-Instance-ID header
